# OS
.DS_Store

# 机密 — 绝不提交：IG 登录会话、令牌、环境变量
cookies.json
*.token
*.pat
.env
.env.*

# Telegram (Telethon) 会话文件 —— 含登录态,泄露=别人能登你账号
*.session
*.session-journal

# 爬取的媒体产物（体积大、可重生）
downloads/
/data/**
!/data/metadata/
!/data/metadata/**
!/data/metadata/*.json
!/data/covers/
/data/covers/**

# 后台运行时数据（旧路径，兼容）
backend/data/
*.db
*.sqlite3

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# 安装器残留的空模板目录
{output_folder}/
